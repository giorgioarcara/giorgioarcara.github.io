plot(NULL, xlim = range(n_seq), ylim = c(0,1),
xlab = "Dimensione del campione (n)",
ylab = "Power statistico",
main = "Curve di power per diversi effect size")
# Aggiunta curve
for (i in 1:length(effect_sizes)) {
power_values <- power_calc(n_seq, effect_sizes[i], alpha)
lines(n_seq, power_values, col = colors[i], lwd = 2)
}
# Legenda
legend("bottomright",
legend = paste("d =", effect_sizes),
col = colors,
lwd = 2)
# Parametri
n <- 50                 # numerosità campionaria
alpha <- 0.05           # livello di significatività
z_alpha <- qnorm(1 - alpha)
# Sequenza di effetti (delta)
delta <- seq(0, 1, length.out = 100)
# Diversi livelli di deviazione standard (o puoi interpretarli come diversi scenari)
sigma_levels <- c(1, 1.5, 2, 2.5)
# Colori per le curve
colors <- c("blue", "red", "green", "purple")
# Plot vuoto
plot(NULL, xlim = range(delta), ylim = c(0, 1),
xlab = "Dimensione dell'effetto (delta)",
ylab = "Power statistico",
main = "Curve di Power per diversi livelli")
# Loop per ogni livello
for (i in 1:length(sigma_levels)) {
sigma <- sigma_levels[i]
# Calcolo power: P(Z > z_alpha - delta*sqrt(n)/sigma)
power <- 1 - pnorm(z_alpha - delta * sqrt(n) / sigma)
# Disegna linea
lines(delta, power, col = colors[i], lwd = 2)
}
# Legenda
legend("bottomright",
legend = paste("sigma =", sigma_levels),
col = colors,
lwd = 2)
# Parametri
alpha <- 0.05
delta <- seq(0, 1, length.out = 100)   # dimensione effetto (Cohen's d)
# Diversi livelli di numerosità
n_levels <- c(20, 50, 100, 200)
colors <- c("blue", "red", "green", "purple")
# Plot vuoto
plot(NULL, xlim = range(delta), ylim = c(0, 1),
xlab = "Dimensione dell'effetto (d)",
ylab = "Power statistico",
main = "Curve di Power - test t (due code)")
# Loop sui diversi n
for (i in 1:length(n_levels)) {
n <- n_levels[i]
df <- n - 1
# valore critico t (due code)
t_crit <- qt(1 - alpha/2, df)
# parametro di non centralità
ncp <- delta * sqrt(n)
# power: P(|T| > t_crit)
power <- 1 - (pt(t_crit, df, ncp) - pt(-t_crit, df, ncp))
# Disegno curva
lines(delta, power, col = colors[i], lwd = 2)
}
# Legenda
legend("bottomright",
legend = paste("n =", n_levels),
col = colors,
lwd = 2)
